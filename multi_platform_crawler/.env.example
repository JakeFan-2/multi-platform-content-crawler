# ============================================================
# 平台账号密码配置
# ============================================================
# 以下配置从原 platforms/*.yaml 迁移而来
# 请填写真实账号密码后使用

# -------------------- 百家号 (baijiahao) --------------------
BAIJIAHAO_USERNAME=你的百度号账号邮箱
BAIJIAHAO_PASSWORD=你的百度号账号密码

# -------------------- 微信公众号 (geekpark_wechat) --------------------
# 微信公众号使用扫码登录，无需账号密码
GEEKPARK_WECHAT_USERNAME=
GEEKPARK_WECHAT_PASSWORD=

# -------------------- 网易号 (netease) --------------------
NETEASE_USERNAME=你的网易号账号邮箱
NETEASE_PASSWORD=你的网易号账号密码

# -------------------- 企鹅号 (qq) --------------------
# 企鹅号使用微信扫码登录，无需账号密码
QQ_USERNAME=
QQ_PASSWORD=

# -------------------- 头条号 (toutiao) --------------------
TOUTIAO_USERNAME=你的头条号账号邮箱
TOUTIAO_PASSWORD=你的头条号账号密码

# -------------------- 微博 (weibo) --------------------
WEIBO_USERNAME=你的微博账号邮箱
WEIBO_PASSWORD=你的微博账号密码

# -------------------- 知乎 (zhihu) --------------------
ZHIHU_USERNAME=你的知乎账号邮箱
ZHIHU_PASSWORD=你的知乎账号密码

# -------------------- 一点资讯 (yidian) --------------------
YIDIAN_USERNAME=你的一点资讯账号邮箱
YIDIAN_PASSWORD=你的一点资讯账号密码

# -------------------- ZAKER (zaker) --------------------
ZAKER_USERNAME=你的ZAKER账号邮箱
ZAKER_PASSWORD=你的ZAKER账号密码

# -------------------- 雪球 (xueqiu) --------------------
# 雪球使用微信扫码登录，无需账号密码
XUEQIU_USERNAME=
XUEQIU_PASSWORD=

# -------------------- 搜狐号 (sohu) --------------------
SOHU_USERNAME=你的搜狐号账号邮箱
SOHU_PASSWORD=你的搜狐号账号密码

# ============================================================
# 飞书多维表格配置
# ============================================================
# 获取方式：
# 1. 登录飞书开放平台 (https://open.feishu.cn/)，创建企业自建应用
# 2. 获取 App ID 和 App Secret
# 3. 开启"多维表格"权限
# 4. 创建多维表格，表头按以下中文字段设置：发布日期、题目、发布平台、发布链接、曝光量、阅读、推荐、评论、点赞、转发、收藏
# 5. 获取文档的 app_token（URL中 docs/ 后面的部分）和 table_id（多维表格的表格ID）

FEISHU_APP_ID=你的飞书应用ID
FEISHU_APP_SECRET=你的飞书应用Secret
FEISHU_APP_TOKEN=你的飞书应用app_token
FEISHU_TABLE_ID=你的飞书多维表格ID

# ============================================================
# 页面定位/判断专用配置（10平台区分，不可重叠）
# ============================================================
# 平台名称（页面定位用）
WECHAT_PLATFORM_NAME=微信公众号
WEIBO_PLATFORM_NAME=微博
TOUTIAO_PLATFORM_NAME=头条号
ZHIHU_PLATFORM_NAME=知乎
BAIJIAHAO_PLATFORM_NAME=百家号
NETEASE_PLATFORM_NAME=网易号
QQ_PLATFORM_NAME=企鹅号
YIDIAN_PLATFORM_NAME=一点资讯
ZAKER_PLATFORM_NAME=ZAKER
XUEQIU_PLATFORM_NAME=雪球

# 账号昵称（侧边栏/页面判断用，需严格按照账号实际页面的信息填写）
WECHAT_ACCOUNT_NICKNAME=账号名称
WEIBO_ACCOUNT_NICKNAME=账号名称
TOUTIAO_ACCOUNT_NICKNAME=账号名称
ZHIHU_ACCOUNT_NICKNAME=账号名称
BAIJIAHAO_ACCOUNT_NICKNAME=账号名称
NETEASE_ACCOUNT_NICKNAME=账号名称
QQ_ACCOUNT_NICKNAME=账号名称
YIDIAN_ACCOUNT_NICKNAME=账号名称
ZAKER_ACCOUNT_NICKNAME=账号名称
XUEQIU_ACCOUNT_NICKNAME=账号名称
